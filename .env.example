# ── Contact (baked into site at build time) ─────────────────
PUBLIC_EMAIL=dookun88@gmail.com
PUBLIC_WHATSAPP=https://wa.me/23057522027
PUBLIC_LINKEDIN=https://www.linkedin.com/in/yashdjsondookun

# ── Cloudflare Pages (recommended) ──────────────────────────
# Project name in Cloudflare dashboard (Workers & Pages)
CLOUDFLARE_PROJECT_NAME=yashdookun

# Optional: for CI or non-interactive deploy (create at dash.cloudflare.com/profile/api-tokens)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Preview branch label for wrangler deploy (default: main)
# CLOUDFLARE_BRANCH=main

# ── Hetzner VPS (optional self-hosted) ──────────────────────

# Server public IP from Hetzner
SERVER_IP=

# SSH key used for bootstrap + deploy (private key path)
SSH_KEY=~/.ssh/id_ed25519

# User created by bootstrap (default: deploy)
DEPLOY_USER=deploy

# Where the app lives on the server
DEPLOY_PATH=/opt/landing-page

# Domain for HTTPS (Caddy auto-provisions Let's Encrypt)
SITE_DOMAIN=yashdookun.com

# First bootstrap only: SSH as root (Hetzner default)
BOOTSTRAP_USER=root

# ── Legacy rsync deploy (optional) ──────────────────────────
DEPLOY_HOST=
DEPLOY_PATH_STATIC=/var/www/site
DEPLOY_METHOD=rsync
