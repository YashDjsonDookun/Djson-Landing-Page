---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { stats } = t(locale);
---

<section class="border-b border-border bg-warm-bg" aria-label="Key statistics">
  <div class="mx-auto max-w-6xl px-5 py-10 sm:px-6 sm:py-12">
    <div class="grid grid-cols-2 gap-6 sm:gap-8 md:grid-cols-4">
      {stats.map((stat, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} text-center`}>
          <p class="text-2xl font-bold tracking-tight text-charcoal sm:text-3xl md:text-4xl" data-count={stat.value}>
            {stat.value}
          </p>
          <p class="mt-1 font-mono text-[10px] tracking-wide text-muted sm:text-xs">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
