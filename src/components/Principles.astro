---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { principles } = t(locale);
---

<section class="border-b border-border">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {principles.heading}
      </h2>
    </div>

    <div class="mt-8 grid gap-3 sm:mt-10 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3">
      {principles.items.map((principle, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 5)} rounded-lg border border-border p-5 transition-all duration-300 hover:border-navy/30 hover:shadow-sm`}>
          <div class="flex items-start gap-3">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-navy/5 font-mono text-xs font-medium text-navy">
              {i + 1}
            </span>
            <div>
              <p class="text-sm font-semibold text-charcoal">{principle.title}</p>
              <p class="mt-1 text-xs leading-relaxed text-muted">{principle.detail}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="reveal mt-8 max-w-2xl text-sm leading-relaxed text-muted">
      {principles.footer}
    </p>
  </div>
</section>
