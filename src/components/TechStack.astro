---
import { t, type Locale } from '../data/i18n';
import { techStack } from '../data/techStack';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { techStackLabel } = t(locale);
---

<section class="border-b border-border" aria-label="Technology stack">
  <div class="mx-auto max-w-6xl px-5 py-8 sm:px-6 sm:py-10">
    <p class="mb-5 text-center font-mono text-[11px] tracking-wide text-muted sm:mb-6 sm:text-xs">{techStackLabel}</p>
    <div class="grid grid-cols-3 gap-4 sm:flex sm:flex-wrap sm:items-center sm:justify-center sm:gap-6 md:gap-8">
      {techStack.map((tech) => (
        <div class="group flex flex-col items-center gap-1.5 text-muted transition-colors hover:text-navy sm:flex-row sm:gap-2">
          <svg class="h-5 w-5 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d={tech.icon} />
          </svg>
          <span class="text-[10px] font-medium sm:text-xs">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
