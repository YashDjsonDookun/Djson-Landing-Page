---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { buildAreas } = t(locale);
const areas = buildAreas.items;
---

<section id="build" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {buildAreas.heading}
      </h2>
    </div>

    <div class="mt-8 grid gap-4 sm:mt-10 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
      {areas.map((area, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 5)} group rounded-lg border border-border p-5 transition-all duration-300 hover:border-navy/30 hover:shadow-md hover:shadow-accent-glow sm:p-6`}>
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-navy/5 text-navy transition-colors group-hover:bg-navy/10">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={area.icon} />
            </svg>
          </div>
          <span class="font-mono text-xs tracking-wide text-navy">
            {area.tag}
          </span>
          <h3 class="mt-2 text-base font-semibold text-charcoal">
            {area.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">
            {area.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
