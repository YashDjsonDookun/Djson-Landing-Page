---
interface Props {
  languages: Record<string, number> | null;
}

const { languages } = Astro.props;

const langColors: Record<string, string> = {
  Python: '#3572A5',
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Shell: '#89e051',
  PowerShell: '#012456',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Makefile: '#427819',
  Dockerfile: '#384d54',
  Jinja: '#a52a22',
  Go: '#00ADD8',
  Java: '#b07219',
  Swift: '#F05138',
};

let bars: { lang: string; pct: number; color: string }[] = [];

if (languages) {
  const total = Object.values(languages).reduce((a, b) => a + b, 0);
  bars = Object.entries(languages)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 5)
    .map(([lang, bytes]) => ({
      lang,
      pct: Math.round((bytes / total) * 100),
      color: langColors[lang] || '#8b949e',
    }));
}
---

{bars.length > 0 && (
  <div class="mt-3">
    <div class="flex h-1.5 overflow-hidden rounded-full bg-tag-bg">
      {bars.map((bar) => (
        <div
          style={`width: ${bar.pct}%; background-color: ${bar.color};`}
          title={`${bar.lang} ${bar.pct}%`}
        />
      ))}
    </div>
    <div class="mt-1.5 flex flex-wrap gap-x-3 gap-y-0.5">
      {bars.map((bar) => (
        <span class="flex items-center gap-1 text-[10px] text-muted">
          <span class="inline-block h-2 w-2 rounded-full" style={`background-color: ${bar.color};`} />
          {bar.lang} {bar.pct}%
        </span>
      ))}
    </div>
  </div>
)}
