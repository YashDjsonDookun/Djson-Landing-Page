---
import { t, locales, localePath, sharedConfig, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const content = t(locale);
const { navLinks, navCta } = content;
---

<header class="sticky top-0 z-50 border-b border-border bg-offwhite/90 backdrop-blur-md transition-colors">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={localePath(locale)} class="text-lg font-semibold tracking-tight text-charcoal transition-colors">
      {sharedConfig.name}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="relative text-sm text-muted transition-colors hover:text-charcoal after:absolute after:-bottom-1 after:left-0 after:h-px after:w-0 after:bg-navy after:transition-all hover:after:w-full"
        >
          {link.label}
        </a>
      ))}

      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          class="flex items-center gap-1 rounded-full border border-border px-3 py-1.5 text-xs font-medium text-muted transition-all hover:border-border-dark hover:text-charcoal"
          aria-label="Change language"
        >
          {locales.find((l) => l.code === locale)?.label ?? 'EN'}
          <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div id="lang-dropdown" class="absolute right-0 top-full mt-1 hidden min-w-[100px] rounded-lg border border-border bg-offwhite py-1 shadow-lg">
          {locales.map((l) => (
            <a
              href={localePath(l.code)}
              class={`block px-4 py-1.5 text-xs transition-colors hover:bg-warm-bg ${l.code === locale ? 'font-semibold text-navy' : 'text-muted hover:text-charcoal'}`}
            >
              {l.flag}&ensp;{l.label}
            </a>
          ))}
        </div>
      </div>

      <button
        id="theme-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-border text-muted transition-all hover:border-border-dark hover:text-charcoal"
        aria-label="Toggle dark mode"
      >
        <svg class="h-4 w-4 dark-hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <svg class="hidden h-4 w-4 dark-visible" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
      </button>

      <a
        href={navCta.href}
        class="rounded-md border border-navy bg-navy px-4 py-2 text-sm font-medium text-offwhite transition-all hover:bg-navy-light hover:shadow-md"
      >
        {navCta.label}
      </a>
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <div class="relative" id="lang-switcher-mobile">
        <button
          id="lang-btn-mobile"
          class="flex h-9 items-center gap-1 rounded-full border border-border px-3 text-xs font-medium text-muted transition-all hover:text-charcoal"
          aria-label="Change language"
        >
          {locales.find((l) => l.code === locale)?.label ?? 'EN'}
          <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div id="lang-dropdown-mobile" class="absolute right-0 top-full mt-1 hidden min-w-[100px] rounded-lg border border-border bg-offwhite py-1 shadow-lg z-50">
          {locales.map((l) => (
            <a
              href={localePath(l.code)}
              class={`block px-4 py-1.5 text-xs transition-colors hover:bg-warm-bg ${l.code === locale ? 'font-semibold text-navy' : 'text-muted hover:text-charcoal'}`}
            >
              {l.flag}&ensp;{l.label}
            </a>
          ))}
        </div>
      </div>
      <button
        id="theme-toggle-mobile"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-border text-muted transition-all hover:text-charcoal"
        aria-label="Toggle dark mode"
      >
        <svg class="h-4 w-4 dark-hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <svg class="hidden h-4 w-4 dark-visible" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="flex h-10 w-10 items-center justify-center rounded"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <div class="mx-auto max-w-6xl space-y-1 px-6 py-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link block rounded px-3 py-2 text-sm text-muted transition-colors hover:bg-warm-bg hover:text-charcoal"
        >
          {link.label}
        </a>
      ))}
      <a
        href={navCta.href}
        class="mobile-nav-link mt-2 block rounded-md border border-navy bg-navy px-3 py-2 text-center text-sm font-medium text-offwhite transition-colors hover:bg-navy-light"
      >
        {navCta.label}
      </a>
    </div>
  </div>
</header>

<style>
  html.dark .dark-hidden { display: none; }
  html.dark .dark-visible { display: block; }
</style>

<script>
  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-nav-link');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  function setupLangDropdown(btnId: string, dropdownId: string) {
    const b = document.getElementById(btnId);
    const d = document.getElementById(dropdownId);
    if (!b || !d) return;
    b.addEventListener('click', (e) => { e.stopPropagation(); d.classList.toggle('hidden'); });
    document.addEventListener('click', () => d.classList.add('hidden'));
  }

  setupLangDropdown('lang-btn', 'lang-dropdown');
  setupLangDropdown('lang-btn-mobile', 'lang-dropdown-mobile');
</script>
