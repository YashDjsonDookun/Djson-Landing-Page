---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const content = t(locale);
const { servicesSection, services } = content;
---

<section id="services" class="relative border-b border-border">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-warm-bg/50 to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0L12 16.5l-5.571-2.25m11.142 0L21.75 16.5 12 21.75 2.25 16.5l4.179-2.25" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {servicesSection.heading}
      </h2>
    </div>
    <p class="reveal reveal-delay-1 mt-2 text-sm text-muted">
      {servicesSection.subtitle}
    </p>

    <div class="mt-8 grid gap-4 sm:mt-10 sm:gap-6 md:grid-cols-2">
      {services.map((service, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} group rounded-lg border border-border bg-offwhite p-5 transition-all duration-300 hover:border-navy/30 hover:shadow-md hover:shadow-accent-glow sm:p-6`}>
          <div class="flex items-baseline gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-navy/5 font-mono text-xs font-medium text-navy transition-colors group-hover:bg-navy/10">
              {String(service.number).padStart(2, '0')}
            </span>
            <h3 class="text-lg font-semibold text-charcoal">
              {service.title}
            </h3>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-muted">
            {service.description}
          </p>

          <div class="mt-4 flex flex-wrap gap-2">
            {service.examples.map((example) => (
              <span class="rounded-md border border-border px-2.5 py-1 text-xs text-muted transition-colors group-hover:border-border-dark">
                {example}
              </span>
            ))}
          </div>

          {service.boundary && (
            <p class="mt-4 rounded-md border-l-2 border-navy/30 bg-navy/5 py-2 pl-4 pr-3 font-mono text-xs leading-relaxed text-muted">
              {service.boundary}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
