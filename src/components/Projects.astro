---
import { t, sharedConfig, type Locale } from '../data/i18n';
import { projects } from '../data/projects';
import TerminalBlock from './TerminalBlock.astro';
import PipelineDiagram from './PipelineDiagram.astro';
import LanguageBar from './LanguageBar.astro';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { projectsSection } = t(locale);

const langData = await Promise.all(
  projects.map((p) =>
    fetch(`${sharedConfig.dataSources.githubApiBase}/${p.repoName}/languages`)
      .then((r) => (r.ok ? r.json() : null))
      .catch(() => null)
  )
);

const morisLexEngineIndex = projects.findIndex((p) => p.name === 'MorisLex Engine');
---

<section id="projects" class="border-b border-border" aria-label="Selected technical work">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {projectsSection.heading}
      </h2>
    </div>
    <p class="reveal reveal-delay-1 mt-2 max-w-2xl text-sm leading-relaxed text-muted">
      {projectsSection.subtitle}
    </p>

    <div class="reveal reveal-delay-2 mt-8 rounded-lg border border-border bg-warm-bg p-5 sm:p-6">
      <h3 class="font-mono text-xs font-medium uppercase tracking-wide text-navy">
        {projectsSection.problemsHeading}
      </h3>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {projectsSection.problems.map((problem) => (
          <li class="flex items-start gap-2.5 text-sm text-charcoal">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-navy" aria-hidden="true" />
            {problem}
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8 space-y-5 sm:mt-10 sm:space-y-6">
      {projects.map((project, i) => {
        const isEngine = i === morisLexEngineIndex;
        const showConnector = isEngine;

        return (
          <div>
            <article class={`reveal reveal-delay-${Math.min((i % 3) + 1, 3)} group rounded-lg border border-border transition-all duration-300 hover:border-navy/30 hover:shadow-md hover:shadow-accent-glow`}>
              <div class="p-3 sm:p-5">
                <TerminalBlock lines={project.terminalLines} title={project.repoName} />
              </div>

              <div class="border-t border-border p-4 sm:p-6">
                <div class="flex items-center gap-2">
                  <span class="inline-block h-2 w-2 rounded-full bg-navy/60 transition-colors group-hover:bg-navy" />
                  <h3 class="font-mono text-sm font-medium text-navy">{project.name}</h3>
                </div>
                <p class="mt-1 text-base font-semibold text-charcoal sm:text-lg">{project.systemTitle}</p>
                <p class="mt-3 text-sm leading-relaxed text-muted">{project.description}</p>

                <div class="mt-5">
                  <p class="font-mono text-[11px] font-medium uppercase tracking-wide text-navy/80">
                    {projectsSection.highlightsLabel}
                  </p>
                  <ul class="mt-3 grid gap-2 sm:grid-cols-2">
                    {project.highlights.map((item) => (
                      <li class="flex items-start gap-2 text-sm text-charcoal">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="mt-5">
                  <PipelineDiagram steps={project.pipeline} />
                </div>

                <div class="mt-4 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-md bg-tag-bg px-2 py-0.5 font-mono text-xs text-muted">{tag}</span>
                  ))}
                </div>

                <LanguageBar languages={langData[i]} />

                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-navy transition-all hover:text-navy-light hover:gap-2.5"
                >
                  {projectsSection.viewGithub}
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
                  </svg>
                </a>
              </div>
            </article>

            {showConnector && (
              <div class="flex items-center justify-center py-2" aria-hidden="true">
                <div class="flex flex-col items-center gap-1">
                  <div class="h-4 w-px bg-navy/30" />
                  <span class="rounded-full bg-navy/10 px-3 py-0.5 font-mono text-[10px] text-navy">{projectsSection.feedsInto}</span>
                  <div class="h-4 w-px bg-navy/30" />
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
