---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { process } = t(locale);
const steps = process.steps;
---

<section id="process" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {process.heading}
      </h2>
    </div>
    <p class="reveal reveal-delay-1 mt-2 text-sm text-muted">
      {process.subtitle}
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} group relative`}>
          {i < steps.length - 1 && (
            <div class="pointer-events-none absolute right-0 top-10 hidden h-px w-6 bg-border-dark lg:block" aria-hidden="true" />
          )}
          <div class="rounded-lg border border-border p-5 transition-all duration-300 hover:border-navy/30 hover:shadow-sm">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-navy/5 text-navy transition-colors group-hover:bg-navy/10">
                <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              </span>
              <span class="font-mono text-xs text-muted">{step.number}</span>
            </div>
            <h3 class="mt-3 text-sm font-semibold text-charcoal">{step.title}</h3>
            <p class="mt-2 text-xs leading-relaxed text-muted">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
