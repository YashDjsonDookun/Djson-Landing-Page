---
import { t, type Locale } from '../data/i18n';

interface Props { locale?: Locale }
const { locale = 'en' } = Astro.props;
const { faq } = t(locale);
const faqs = faq.items;
---

<section id="faq" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 md:py-20">
    <div class="reveal flex items-center gap-3">
      <svg class="h-6 w-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
      </svg>
      <h2 class="text-2xl font-bold tracking-tight text-charcoal md:text-3xl">
        {faq.heading}
      </h2>
    </div>
    <p class="reveal reveal-delay-1 mt-2 text-sm text-muted">
      {faq.subtitle}
    </p>

    <div class="mt-8 grid items-start gap-4 sm:mt-10 md:grid-cols-2">
      {faqs.map((item, i) => (
        <details class={`reveal reveal-delay-${Math.min(i + 1, 4)} group rounded-lg border border-border transition-all hover:border-navy/30`}>
          <summary class="flex cursor-pointer items-start gap-3 p-5 text-sm font-semibold text-charcoal select-none [&::-webkit-details-marker]:hidden">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-navy transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
            {item.q}
          </summary>
          <div class="px-5 pb-5 pl-12 text-sm leading-relaxed text-muted">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
